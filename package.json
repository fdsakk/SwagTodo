{
  "name": "swag-todo",
  "version": "1.0.0",
  "description": "Swag Todo is a local-first desktop app for managing tasks, projects, labels, sessions, and health tracking.",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome check .",
    "check": "biome check --write --unsafe",
    "test": "bun run test:store",
    "test:store": "node -r sucrase/register/ts -r ./src/renderer/src/store/tests/register-aliases.cjs --test src/renderer/src/store/tests/*.test.ts src/renderer/src/utils/*.test.ts src/main/tests/*.test.ts",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "bun run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "bun run build && electron-builder --dir",
    "build:win": "bun run build && electron-builder --win",
    "build:mac": "bun run build && electron-builder --mac",
    "build:linux": "bun run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "better-sqlite3": "^12.9.0",
    "rrule": "^2.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@base-ui/react": "^1.4.1",
    "@biomejs/biome": "^2.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@fontsource/geist-sans": "^5.2.5",
    "@tailwindcss/vite": "^4.2.4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.19.1",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.1",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.11.0",
    "postcss": "^8.5.9",
    "react-colorful": "^5.6.1",
    "react-day-picker": "^9.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hotkeys-hook": "^5.2.4",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "vite": "^7.2.6",
    "zustand": "^5.0.12"
  }
}
